# SliceMatic — environment configuration
# Copy this file to `.env.local` and fill in real values. NEVER commit `.env.local`.

# --- Supabase (Postgres + Auth) ---
# Project URL, e.g. https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Public anon key (safe to expose to the browser; RLS protects the data).
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY

# --- OpenRouter (AI ordering agent) ---
# Server-side ONLY. Used in the /api route; never sent to the client.
OPENROUTER_API_KEY=sk-or-v1-YOUR-OPENROUTER-KEY
# Model string — swappable without code changes.
# e.g. openai/gpt-4o-mini  or  anthropic/claude-3.5-haiku
OPENROUTER_MODEL=openai/gpt-4o-mini
